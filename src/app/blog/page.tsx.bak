import Link from 'next/link'
import { getAllPosts } from '@/lib/mdx'

export default function Blog() {
  const posts = getAllPosts()

  return (
    <div className="container mx-auto px-6 py-24 min-h-screen bg-void-black text-white">
      <h1 className="text-4xl font-bold mb-12 font-mono">
        <span className="text-bio-green">&gt;</span> BLOG_POSTS
      </h1>
      <div className="grid gap-8">
        {posts.map((post) => (
          <Link
            key={post.slug}
            href={`/blog/${post.slug}`}
            className="block p-8 border border-white/10 rounded-xl hover:border-bio-green/50 transition-colors bg-white/5"
          >
            <h2 className="text-2xl font-bold mb-2 font-mono">{post.meta.title}</h2>
            <div className="flex gap-4 text-sm text-gray-400 mb-4 font-mono">
              <span>{post.meta.date}</span>
              <span>{post.meta.tags.join(', ')}</span>
            </div>
            <p className="text-gray-300">{post.meta.description}</p>
          </Link>
        ))}
      </div>
    </div>
  )
}
